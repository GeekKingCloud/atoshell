# .atoshell/config.env — project configuration for atoshell
#
# Shared ticket files (`queue.json`, `backlog.json`, `done.json`) are intended
# to be committed. Local-only files such as `config.env` and `meta.json` should
# be gitignored.

# ── Column names ──────────────────────────────────────────────────────────────
# Rename these to match your workflow. They control how tickets are displayed
# and which JSON file each status lives in.
STATUS_BACKLOG="Backlog"          # Untriaged / parked / failed — lives in backlog.json
STATUS_READY="Ready"              # Ready to work — lives in queue.json
STATUS_IN_PROGRESS="In Progress"  # Being worked — lives in queue.json
STATUS_DONE="Done"                # Completed work — lives in done.json

# ── Username ──────────────────────────────────────────────────────────────────
# Your name, used as the author on tickets and comments and as the value of "me"
# when filtering or assigning. Defaults to "undefined" unless set here.
#USERNAME="Your Name"

# ── Priority labels (highest → lowest) ────────────────────────────────────────
PRIORITY_0="P0"
PRIORITY_1="P1"
PRIORITY_2="P2"
PRIORITY_3="P3"

# ── Size labels (smallest → largest) ──────────────────────────────────────────
SIZE_0="XS"
SIZE_1="S"
SIZE_2="M"
SIZE_3="L"
SIZE_4="XL"

# ── Ticket types ───────────────────────────────────────────────────────────────
TYPE_0="Bug"
TYPE_1="Feature"
TYPE_2="Task"

# ── Timestamps ────────────────────────────────────────────────────────────────
# Controls created_at, updated_at, and ticket comment timestamps.
# Use an IANA name such as "America/Mexico_City"
ATOSHELL_TIMEZONE="UTC"

# ── Blocker handling (dependency budget) ───────────────────────────────────────
# How much size-budget to spend clearing blockers for each priority tier.
# Size cost = size rank: XS=0, S=1, M=2, L=3, XL=4. P0 blockers always cost 0.
# Leave UNBLOCK_P0_BUDGET empty for infinite (always worth clearing all blockers).
UNBLOCK_P0_BUDGET=""   # infinite
UNBLOCK_P1_BUDGET="3"  # e.g. 1×L, 3×S, or 1×S + 1×M
